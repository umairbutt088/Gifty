EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public app URL used in recipient delivery links (web or universal link)
# Dev web: http://localhost:8081
# Production: https://your-gifty-domain.com
EXPO_PUBLIC_APP_URL=http://localhost:8081

# Supabase Dashboard → Authentication → URL Configuration
# Site URL: gifty://
# Redirect URLs (add every line):
#   gifty://reset-password
#   gifty://**
#   exp+gifty://**
# If testing reset in a desktop browser with Expo web, also add:
#   http://localhost:8081/reset-password

# --- Recipient SMS / email (deferred — set RECIPIENT_NOTIFICATIONS_ENABLED in recipient-delivery.ts) ---
# Deploy: supabase functions deploy send-recipient-notification
# Set secrets in Supabase Dashboard → Edge Functions → Secrets:
#
# TWILIO_ACCOUNT_SID=...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+1...
# RECIPIENT_APP_URL=https://your-gifty-domain.com
#
# Optional email (Resend — free tier available):
# RESEND_API_KEY=...
# RESEND_FROM_EMAIL=Gifty <hello@your-domain.com>
#
# SMS is paid via Twilio after trial credits (~$0.01–0.08 per message depending on country).
